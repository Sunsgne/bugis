{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "Bugis · DCI/EVPN 运营总览",
  "uid": "bugis-overview",
  "tags": ["bugis", "dci", "evpn"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "活跃专线",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "bugis_circuits_active", "refId": "A" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "专线总数",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "bugis_circuits_total", "refId": "A" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "设备总数",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "bugis_devices_total", "refId": "A" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "活跃带宽 (Mbps)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "bugis_active_bandwidth_mbps", "refId": "A" }]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "活跃告警",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [{ "expr": "bugis_active_alarms", "refId": "A" }]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "活跃专线趋势",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "bugis_circuits_active", "refId": "A", "legendFormat": "active" },
        { "expr": "bugis_circuits_total", "refId": "B", "legendFormat": "total" }
      ]
    },
    {
      "id": 7,
      "type": "piechart",
      "title": "设备厂商分布",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "bugis_devices_by_vendor",
          "refId": "A",
          "legendFormat": "{{vendor}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "专线状态分布",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "bugis_circuits_by_status",
          "refId": "A",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "告警 (按级别)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "bugis_alarms_by_severity",
          "refId": "A",
          "legendFormat": "{{severity}}"
        }
      ]
    }
  ]
}
