# Copy to deploy/prod.env (gitignored) for production deploys:
#   cp deploy/prod.env.example deploy/prod.env
#   source deploy/prod.env && ./scripts/deploy-prod.sh
#
# Leave password fields empty to auto-generate random secrets on first deploy.

# --- Remote SSH ---
PROD_SSH_HOST=your-server-ip-or-hostname
PROD_SSH_PORT=22
PROD_SSH_USER=root
PROD_SSH_PASSWORD=your-ssh-password-here
PROD_REMOTE_DIR=/root/bugis-prod

# --- Stack secrets (written to remote .env) ---
POSTGRES_USER=bugis
POSTGRES_PASSWORD=
POSTGRES_DB=bugis
BUGIS_SECRET_KEY=
GRAFANA_ADMIN_PASSWORD=

# Platform admin (reset on each deploy)
BUGIS_ADMIN_USER=admin
BUGIS_ADMIN_PASS=

# Tenant portal account (created by seed, password set at deploy)
BUGIS_PORTAL_USER=portal
BUGIS_PORTAL_PASS=

# Production security (required when BUGIS_APP_ENV=production)
BUGIS_FIRST_SUPERUSER_PASSWORD=
BUGIS_WEBHOOK_TOKEN=
