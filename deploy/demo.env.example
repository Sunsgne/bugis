# Copy to deploy/demo.env (gitignored) for demo deploys:
#   cp deploy/demo.env.example deploy/demo.env
#   source deploy/demo.env && ./scripts/deploy-demo.sh
#
# Local compose smoke test (without SSH):
#   docker compose -f docker-compose.demo.yml --env-file deploy/demo.env up --build

# --- Remote SSH (deploy-demo.sh) ---
DEMO_SSH_HOST=your-server-ip-or-hostname
DEMO_SSH_PORT=22
DEMO_SSH_USER=root
DEMO_SSH_PASSWORD=your-ssh-password-here
DEMO_REMOTE_DIR=/root/bugis

# --- Stack secrets (written to remote .env for docker compose) ---
POSTGRES_USER=bugis
POSTGRES_PASSWORD=change-me-strong-postgres-password
POSTGRES_DB=bugis
BUGIS_SECRET_KEY=change-me-long-random-jwt-secret
BUGIS_APP_ENV=production
BUGIS_DEBUG=false
BUGIS_DRY_RUN=false
BUGIS_TELEMETRY_SIMULATION=false
GRAFANA_ADMIN_PASSWORD=change-me-grafana-admin-password

# Platform login (reset on each deploy via reset_admin_password)
BUGIS_DEMO_USER=admin
BUGIS_DEMO_PASS=change-me-strong-admin-password

# Tenant portal demo (seeded by ensure_demo for BANK01)
# Login at http://<host>:3300/portal — same login page, auto-redirects
# Only frontend :3300 is published; backend/DB/Prometheus/Grafana are internal-only.
BUGIS_PORTAL_USER=bank_portal
BUGIS_PORTAL_PASS=change-me-strong-portal-password
