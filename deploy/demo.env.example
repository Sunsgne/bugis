# Copy to deploy/demo.env (gitignored) for demo deploys:
#   cp deploy/demo.env.example deploy/demo.env
#   source deploy/demo.env && ./scripts/deploy-demo.sh
#
# Local compose smoke test (without SSH):
#   docker compose -f docker-compose.demo.yml --env-file deploy/demo.env up --build

# --- Remote SSH (deploy-demo.sh) ---
DEMO_SSH_HOST=203.117.117.196
DEMO_SSH_PORT=2333
DEMO_SSH_USER=root
DEMO_SSH_PASSWORD=your-password-here
DEMO_REMOTE_DIR=/root/bugis

# --- Stack secrets (written to remote .env for docker compose) ---
POSTGRES_USER=bugis
POSTGRES_PASSWORD=change-me-strong-postgres-password
POSTGRES_DB=bugis
BUGIS_SECRET_KEY=change-me-long-random-jwt-secret
GRAFANA_ADMIN_PASSWORD=admin
