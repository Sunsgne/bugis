# Bugis HA deployment inventory — copy to deploy/ha/inventory.env and fill in.
# Then: source deploy/ha/inventory.env && ./scripts/ha/deploy-ha.sh

# --- SSH ---
HA_SSH_USER=root
HA_SSH_PORT=22
# HA_SSH_PASSWORD=          # optional; prefer SSH keys

# --- Virtual IP / public entry (optional, for keepalived) ---
HA_VIP=
HA_PUBLIC_URL=https://bugis.example.com

# --- Database primary (required) ---
HA_DB_HOST=10.0.0.20
HA_DB_PORT=5432
# Bind PostgreSQL on the DB host (use private IP or 0.0.0.0 + firewall for App nodes)
HA_DB_BIND=0.0.0.0
POSTGRES_USER=bugis
POSTGRES_PASSWORD=change-me-strong-postgres-password
POSTGRES_DB=bugis

# --- Database standby (optional, streaming replica — manual failover) ---
HA_DB_STANDBY_HOST=

# --- Application nodes (comma-separated, first = scheduler leader + migrations) ---
HA_APP_HOSTS=10.0.0.10,10.0.0.11
HA_APP_HTTP_PORT=3300
# Backend /metrics bind on each App host (private IP or 0.0.0.0 + firewall for Obs Prometheus)
HA_APP_METRICS_BIND=0.0.0.0
HA_APP_METRICS_PORT=8000

# --- Load balancer node(s) (comma-separated) ---
HA_LB_HOSTS=10.0.0.1
HA_LB_HTTP_PORT=80
HA_LB_HTTPS_PORT=443

# --- Observability (optional; leave empty to skip) ---
HA_OBS_HOST=
# Bound to 127.0.0.1 on the Obs host — use SSH tunnel for browser access
HA_PROMETHEUS_PORT=9090
HA_GRAFANA_PORT=3000

# --- Shared secrets (must be identical on all app nodes) ---
BUGIS_SECRET_KEY=change-me-long-random-jwt-secret
BUGIS_DRY_RUN=false
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

# --- Bootstrap (first deploy only on leader app node) ---
BUGIS_RUN_SEED=true
BUGIS_RUN_DEMO=false
