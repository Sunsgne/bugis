{% import 'juniper/_macros.j2' as jun %}
{% set mode = endpoint.access_mode.value if endpoint.access_mode else 'dot1q' %}
{% set svid = endpoint.vlan_id or circuit.vlan_id %}
{% set cvid = endpoint.inner_vlan_id %}
{% set ifl = jun.l2_ifl(endpoint, mode, svid) %}
## Juniper Junos - EVPN-MPLS L3 (IRB / Type-5)  circuit={{ circuit.code }} vrf={{ circuit.vrf_name }}
## device={{ device.name }} ac={{ mode }} s-vid={{ svid }}

{{ jun.l2_ac(endpoint, circuit, mode, svid, cvid) }}
{{ jun.evpn_l2_instance(circuit, ifl, mode, svid) }}
set routing-instances {{ jun.evi_name(circuit) }} routing-interface irb.{{ circuit.vni }}
set interfaces irb unit {{ circuit.vni }} family inet address {{ endpoint.gateway_ip }}/24
set interfaces irb unit {{ circuit.vni }} mtu {{ circuit.mtu }}
set routing-instances {{ circuit.vrf_name }} instance-type vrf
set routing-instances {{ circuit.vrf_name }} interface irb.{{ circuit.vni }}
set routing-instances {{ circuit.vrf_name }} route-distinguisher {{ circuit.route_distinguisher }}
set routing-instances {{ circuit.vrf_name }} vrf-target target:{{ circuit.route_target }}
set routing-instances {{ circuit.vrf_name }} protocols evpn ip-prefix-routes advertise direct-nexthop
set routing-instances {{ circuit.vrf_name }} protocols evpn ip-prefix-routes encapsulation mpls
set routing-instances {{ circuit.vrf_name }} protocols evpn default-gateway no-gateway-community
