! FRRouting + SONiC - 设备初始化基线 (baseline)  {{ device.name }}
! role={{ device.role }} loopback={{ device.loopback_ip }} asn={{ asn }}
! --- SONiC base (config_db) ---
! sudo config hostname {{ device.name }}
! sudo config ntp add {{ ntp_server }}
! sudo config syslog add {{ syslog_server }}
! --- FRR (vtysh) ---
configure terminal
hostname {{ device.name }}
!
interface lo
 ip address {{ device.loopback_ip }}/32
!
! ---- Underlay OSPF ----
router ospf
 ospf router-id {{ device.loopback_ip }}
 network {{ device.loopback_ip }}/32 area 0
!
! ---- BGP EVPN overlay ----
router bgp {{ asn }}
 bgp router-id {{ device.loopback_ip }}
 neighbor EVPN-RR peer-group
 neighbor EVPN-RR remote-as {{ asn }}
 neighbor EVPN-RR update-source lo
{% for rr in rr_peers %}
 neighbor {{ rr }} peer-group EVPN-RR
{% endfor %}
 address-family l2vpn evpn
  neighbor EVPN-RR activate
  advertise-all-vni
{% if is_rr %}
  neighbor EVPN-RR route-reflector-client
{% endif %}
 exit-address-family
exit
end
