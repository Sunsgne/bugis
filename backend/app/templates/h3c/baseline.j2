#
# H3C Comware7 - 设备初始化基线 (baseline)  {{ device.name }}
# role={{ device.role }} loopback={{ device.loopback_ip }} asn={{ asn }}
#
sysname {{ device.name }}
#
clock timezone BJ add 08:00:00
clock protocol ntp
ntp-service enable
ntp-service unicast-server {{ ntp_server }}
#
info-center loghost {{ syslog_server }}
#
snmp-agent
snmp-agent sys-info version v2c v3
snmp-agent community read {{ snmp_community }}
#
stp global enable
#
interface LoopBack0
 ip address {{ device.loopback_ip }} 255.255.255.255
#
# ---- Underlay (OSPF) ----
ospf 1 router-id {{ device.loopback_ip }}
 area 0.0.0.0
  network {{ device.loopback_ip }} 0.0.0.0
#
# ---- VXLAN / EVPN global ----
l2vpn enable
vxlan tunnel mac-learning disable
vxlan tunnel arp-learning enable
#
interface Nve1
 source {{ device.loopback_ip }}
#
# ---- BGP EVPN overlay ----
bgp {{ asn }}
 router-id {{ device.loopback_ip }}
 group EVPN-RR internal
{% for rr in rr_peers %}
 peer {{ rr }} group EVPN-RR
 peer {{ rr }} connect-interface LoopBack0
{% endfor %}
{% if is_rr %}
 #
 # this node is a Route Reflector
{% endif %}
 address-family l2vpn evpn
  peer EVPN-RR enable
{% if is_rr %}
  peer EVPN-RR reflect-client
  undo policy vpn-target
{% endif %}
#
return
