{# Huawei VRP / CE EVPN VXLAN shared fragments #}
{% macro cust_label(circuit) -%}
{% if circuit.tenant %}{{ circuit.tenant.name }}{% else %}CUST{{ circuit.tenant_id }}{% endif %}:{{ circuit.code }}
{%- endmacro %}

{% macro l2_ifname(endpoint, mode, svid) -%}
{%- if mode == 'access' -%}
{{ endpoint.interface_name }}
{%- else -%}
{{ endpoint.interface_name }}.{{ svid or 1 }}
{%- endif -%}
{%- endmacro %}

{% macro qos_policy_name(circuit) -%}
tp-{{ circuit.code }}
{%- endmacro %}

{% macro qos_behavior_name(circuit) -%}
tb-{{ circuit.code }}
{%- endmacro %}

{% macro qos_policy_objects(circuit) -%}
{% if circuit.bandwidth_mbps %}
# QoS CAR (VRP/CE): a single shared 'ANY' classifier (match-any) + one traffic
# behavior per circuit carrying the rate (car cir, unit = kbps), referenced by a
# per-circuit traffic-policy. A bandwidth change only updates the behavior's
# 'car cir'; the classifier/policy/interface binding stay untouched.
# NB: VRP8/CE applies the default color action (green & yellow pass, red
# discard) automatically, so only 'car cir <kbps> kbps' is emitted.
traffic classifier ANY type or
 if-match any
#
traffic behavior {{ qos_behavior_name(circuit) }}
 car cir {{ circuit.bandwidth_mbps * 1024 }} kbps
#
traffic policy {{ qos_policy_name(circuit) }}
 classifier ANY behavior {{ qos_behavior_name(circuit) }} precedence 5
#
{% endif %}
{%- endmacro %}

{% macro qos_policy_remove(circuit) -%}
{% if circuit.bandwidth_mbps %}
# Recover this circuit's rate-limit objects. The shared 'ANY' classifier is left
# in place because it is reused by every circuit's traffic-policy.
undo traffic policy {{ qos_policy_name(circuit) }}
undo traffic behavior {{ qos_behavior_name(circuit) }}
#
{% endif %}
{%- endmacro %}

{% macro bridge_domain_evpn(circuit) -%}
# NB: Huawei VRP8/CE has no per-service frame-size command in the bridge-domain
# view; jumbo/frame size follows the underlay physical interface and is managed
# outside this provisioning scope.
bridge-domain {{ circuit.vni }}
 vxlan vni {{ circuit.vni }}
 evpn
  route-distinguisher {{ circuit.route_distinguisher }}
  vpn-target {{ circuit.route_target }} export-extcommunity
  vpn-target {{ circuit.route_target }} import-extcommunity
{%- endmacro %}

{% macro l2_subif(endpoint, circuit, mode, svid, cvid) -%}
interface {{ l2_ifname(endpoint, mode, svid) }} mode l2
{% if mode != 'access' %}
 description {{ cust_label(circuit) }}
{% endif %}
{% if mode == 'access' %}
 encapsulation untag
{% elif mode == 'qinq' %}
 encapsulation qinq vid {{ svid }} ce-vid {{ cvid }}
{% else %}
 encapsulation dot1q vid {{ svid }}
{% endif %}
 bridge-domain {{ circuit.vni }}
{% if circuit.bandwidth_mbps %}
 traffic-policy {{ qos_policy_name(circuit) }} inbound
 traffic-policy {{ qos_policy_name(circuit) }} outbound
 statistics enable
{% endif %}
{%- endmacro %}

{% macro nve_vni(circuit) -%}
interface Nve1
 vni {{ circuit.vni }} head-end peer-list protocol bgp
{%- endmacro %}
