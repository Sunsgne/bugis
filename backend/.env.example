# Bugis backend configuration (copy to .env). All vars are prefixed BUGIS_.

BUGIS_APP_ENV=development
BUGIS_DEBUG=true

# Database. SQLite by default; for PostgreSQL use:
# BUGIS_DATABASE_URL=postgresql+psycopg://bugis:bugis@db:5432/bugis
BUGIS_DATABASE_URL=sqlite:///./bugis.db

# Security - CHANGE in production (>= 32 random chars; enforced when APP_ENV=production)
BUGIS_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
BUGIS_ACCESS_TOKEN_EXPIRE_MINUTES=480
BUGIS_EXPOSE_OPENAPI=false
# Comma-separated reverse-proxy IPs that may set X-Forwarded-For
# BUGIS_TRUSTED_PROXY_IPS=10.0.0.1
# Bearer token for /metrics (recommended in production)
# BUGIS_METRICS_TOKEN=generate-a-random-token
BUGIS_SKIP_SECURITY_CHECKS=false

# Provisioning: true = render only, no live push (default in development).
BUGIS_DRY_RUN=true
BUGIS_VNI_BASE=30000
# Verify NETCONF SSH host keys (recommended true in production)
BUGIS_NETCONF_HOSTKEY_VERIFY=false
# HA follower nodes: set false to disable background provisioning worker
BUGIS_WORKER_ENABLED=true

# CORS (explicit origins in production; never use * with credentials)
# BUGIS_CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Bootstrap admin — rotate immediately after first login in production
BUGIS_FIRST_SUPERUSER=admin
BUGIS_FIRST_SUPERUSER_PASSWORD=admin123

# Northbound webhook (rotate in production; min 16 chars when APP_ENV=production)
BUGIS_WEBHOOK_TOKEN=bugis-webhook-token
